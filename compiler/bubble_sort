@int arr[5] = {5, 2, 4, 1, 3} $
@int n is 5 $
@int i $
@int j $
@int temp $

iterate (i = 0 $ i < n - 1 $ i = i + 1) {
    iterate (j = 0 $ j < n - i - 1 $ j = j + 1) {
        if (arr[j] > arr[j + 1]) {
            temp = arr[j] $
            arr[j] = arr[j + 1] $
            arr[j + 1] = temp $
        }
    }
}

iterate (i = 0 $ i < n $ i = i + 1) {
    show(arr[i]) $
}
