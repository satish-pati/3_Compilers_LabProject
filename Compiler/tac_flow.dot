digraph TAC {
  node [shape=box, style=filled, fillcolor=lightblue];
  compound=true;

  subgraph cluster_global {
    label="Global Scope";
    style=rounded; color=gray40; bgcolor="#f5f5dc";
    n0 [label="0 x = 1e+40"];
    n0 -> n1 [style=dashed];
    n1 [label="1 x_to_char = (char)x"];
    n1 -> n2 [style=dashed];
    n2 [label="2 x_to_short = (short)x"];
    n2 -> n3 [style=dashed];
    n3 [label="3 x_to_int = (int)x"];
    n3 -> n4 [style=dashed];
    n4 [label="4 x_to_long = (long)x"];
    n4 -> n5 [style=dashed];
    n5 [label="5 x_to_float = (float)x"];
    n5 -> n6 [style=dashed];
    n6 [label="6 printfloat x"];
    n6 -> n7 [style=dashed];
    n7 [label="7 printchar x_to_char"];
    n7 -> n8 [style=dashed];
    n8 [label="8 printint x_to_short"];
    n8 -> n9 [style=dashed];
    n9 [label="9 printint x_to_int"];
    n9 -> n10 [style=dashed];
    n10 [label="10 printint x_to_long"];
    n10 -> n11 [style=dashed];
    n11 [label="11 printfloat x_to_float"];
  }
}
