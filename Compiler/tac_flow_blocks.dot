digraph TAC_Blocks {
  node [shape=record, style=filled, fillcolor=lightblue];
  rankdir=TB;

  bb0 [label="{<b>Global Scope|0 x = 1e+40\l1 x_to_char = (char)x\l2 x_to_short = (short)x\l3 x_to_int = (int)x\l4 x_to_long = (long)x\l5 x_to_float = (float)x\l6 printfloat x\l7 printchar x_to_char\l8 printint x_to_short\l9 printint x_to_int\l10 printint x_to_long\l11 printfloat x_to_float\l}"];

  // Control flow edges
}
