digraph TAC_Blocks {
  node [shape=record, style=filled, fillcolor=lightblue];
  rankdir=TB;

  bb3 [label="{<b>Global Scope|15 printint sum\l}"];
  bb2 [label="{<b>Global Scope|9 t1 = i * 4\l10 t2 = sum + arr[t1]\l11 sum = t2\l12 t0 = i + 1\l13 i = t0\l14 goto 8\l}"];
  bb1 [label="{<b>Global Scope|8 if i \>= n goto 15\l}"];
  bb0 [label="{<b>Global Scope|0 arr[0] = 10\l1 arr[4] = 20\l2 arr[8] = 30\l3 arr[12] = 40\l4 arr[16] = 50\l5 n = 5\l6 sum = 0\l7 i = 0\l}"];

  // Control flow edges
  bb0 -> bb1 [style=dashed, color=black];
  bb1 -> bb3 [label="T", color=green, penwidth=2];
  bb1 -> bb2 [label="F", color=red, penwidth=2];
  bb2 -> bb1 [label="goto", penwidth=2];
}
